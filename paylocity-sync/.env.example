# ─────────────────────────────────────────────────────────────────────────────
# Paylocity Sync — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Safety ────────────────────────────────────────────────────────────────────
# Keep true until test_connections.py passes for all systems.
DRY_RUN=true

# ── Paylocity ─────────────────────────────────────────────────────────────────
# Obtain from: Paylocity > Company Setup > Integrations > API Credentials
PAYLOCITY_CLIENT_ID=
PAYLOCITY_CLIENT_SECRET=
PAYLOCITY_COMPANY_ID=

# ── Central Reach ─────────────────────────────────────────────────────────────
# These were emailed to centralreachintegration@projecthopesc.org
CR_CLIENT_ID=eaa1842c267f44e2b1fc8bc61f87a9ae
CR_CLIENT_SECRET=64102e4e990b48849aa919df2342cdea
CR_API_KEY=CR-API-ProjectHop-VaTnRCdV0OUovqEPWBNdg
CR_BASE_URL=https://api.centralreach.com

# ── Google Workspace ──────────────────────────────────────────────────────────
# Option A (local): path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# Option B (GitHub Actions): paste the entire JSON key as a single-line string
# Store this as a GitHub Actions secret named GOOGLE_SERVICE_ACCOUNT_KEY
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# A Google Workspace super-admin email that the service account will impersonate
GOOGLE_ADMIN_EMAIL=admin@projecthopesc.org

# Your Google Workspace primary domain
GOOGLE_DOMAIN=projecthopesc.org

# ── Sync behaviour ────────────────────────────────────────────────────────────
# Temporary password assigned to newly created Google accounts.
# Users are forced to change it on first login.
DEFAULT_TEMP_PASSWORD=ChangeMe2024!

# Comma-separated Paylocity status values that count as "active"
ACTIVE_STATUSES=Active
